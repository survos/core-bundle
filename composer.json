{
    "name": "survos/core-bundle",
    "description": "Traits and Interfaces common to other Survos bundles",
    "keywords": [
        "symfony entity routing"
    ],
    "license": "MIT",
    "type": "symfony-bundle",
    "require": {
        "php": "^8.5",
        "symfony/config": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/http-kernel": "^8.1",
        "symfony/serializer": "^8.1",
        "twig/twig": "^3.4",
        "symfony/string": "^8.1",
        "symfony/property-access": "^8.1",
        "doctrine/common": "^3.5",
        "ext-zlib": "*"
    },
    "require-dev": {
        "doctrine/orm": "^2.12 || ^3.3",
        "phpstan/phpstan": "^2.0",
        "symfony/browser-kit": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/phpunit-bridge": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/var-dumper": "^8.1",
        "symfony/asset-mapper": "^8.1",
        "symfony/console": "^8.1",
        "easycorp/easyadmin-bundle": "^4.24",
        "symfony/error-handler": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Survos\\CoreBundle\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.1-dev"
        }
    }
}
