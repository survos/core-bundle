{
    "name": "survos/core-bundle",
    "description": "Traits and Interfaces common to other Survos bundles",
    "keywords": [
        "symfony entity routing"
    ],
    "license": "MIT",
    "type": "symfony-bundle",
    "require": {
        "php": "^8.4",
        "symfony/config": "^7.3||^8.0",
        "symfony/dependency-injection": "^7.3||^8.0",
        "symfony/http-kernel": "^7.3||^8.0",
        "symfony/serializer": "^7.3||^8.0",
        "twig/twig": "^3.4",
        "symfony/string": "^7.3||^8.0",
        "symfony/property-access": "^7.3||^8.0",
        "doctrine/common": "^3.5",
        "ext-zlib": "*"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "doctrine/orm": "^2.12 || ^3.3",
        "phpstan/phpstan": "^2.0",
        "symfony/browser-kit": "^7.3||^8.0",
        "symfony/framework-bundle": "^7.3||^8.0",
        "symfony/phpunit-bridge": "^7.3||^8.0",
        "symfony/twig-bundle": "^7.3||^8.0",
        "symfony/var-dumper": "^7.3||^8.0",
        "symfony/asset-mapper": "^7.3||^8.0",
        "symfony/console": "^7.3||^8.0",
        "easycorp/easyadmin-bundle": "^4.24",
        "symfony/error-handler": "^7.4||^8.0"
    },
    "autoload": {
        "psr-4": {
            "Survos\\CoreBundle\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.1-dev"
        }
    }
}
